# Server config (constitution Principle VIII). Copy to .env and adjust
# locally — .env is git-ignored and never committed.
#
# PORT must stay equal to client/.env's VITE_BACKEND_PORT: both encode the
# dev backend port that the client's /catalog proxy and WS connection target.
PORT=6080
CATALOG_ROOT=./catalog
HOST_REASSIGN_GRACE_MS=120000
REQUIRE_SONG_CONSENT=false
# Built client SPA root served as a static fallback (infrastructure.md
# "Deployment (Railway + Terraform)"). Unused in local dev — the client
# runs its own Vite dev server instead, so a nonexistent path here is
# harmless (every request just 404s through client-static.ts).
CLIENT_ROOT=../client/dist

# --- Optional account layer (constitution v1.5.0; infrastructure.md User
# Accounts). ALL of these are optional: with DATABASE_URL unset the whole
# account layer self-disables and the server runs exactly as before — auth
# routes are inert, every participant anonymous (design §2). NEVER commit a
# real secret here; .env.example holds placeholders only.
#
# Postgres connection string for the durable account store (User /
# CatalogueMembership / AuthSession). Absent ⇒ accounts disabled.
DATABASE_URL=
# Hand-rolled Google/GitHub OAuth client credentials (infrastructure.md
# OAuth flow). Real values live in 1Password, pushed to Railway as sealed
# vars (design §12.4) — placeholders here only.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
# Secret used to sign/verify the AuthSession cookie and derive OAuth state
# (§13 S1/S2). A long random string in real deployments; placeholder here.
SESSION_COOKIE_SECRET=change-me-to-a-long-random-string
# Public origin the app is reached at, used to build OAuth redirect_uri and
# the Secure cookie's context. Dev: http://localhost:<vite-port>.
PUBLIC_BASE_URL=http://localhost:5173
