{
  "name": "@sync-tab-scroll/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r src/accounts/migrations dist/accounts/migrations",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "node --env-file-if-exists=.env node_modules/vitest/vitest.mjs run",
    "set-catalogue-owner": "tsx --env-file-if-exists=.env src/set-catalogue-owner.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sync-tab-scroll/shared": "workspace:*",
    "pg": "^8.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.9"
  }
}
